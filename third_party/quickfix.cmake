# Thin build wrapper for quickfix submodule (v1.15.1)
# Patches throw() specs at configure time for C++17 compatibility.

set(QUICKFIX_DIR ${CMAKE_CURRENT_SOURCE_DIR}/third_party/quickfix)
set(QUICKFIX_SRC ${QUICKFIX_DIR}/src/C++)
set(QUICKFIX_PATCH_STAMP "${CMAKE_CURRENT_BINARY_DIR}/quickfix_patched.stamp")

# Generate Allocator.h and config.h if missing (quickfix expects them)
if(NOT EXISTS "${QUICKFIX_SRC}/Allocator.h")
    file(WRITE "${QUICKFIX_SRC}/Allocator.h" "/* Generated by cmake */\n")
endif()
if(NOT EXISTS "${QUICKFIX_DIR}/config.h")
    file(WRITE "${QUICKFIX_DIR}/config.h" "/* Generated by cmake */\n")
endif()

# Create include/quickfix symlink so consumers can #include "quickfix/Session.h"
set(QUICKFIX_INCLUDE_BASE "${QUICKFIX_DIR}/include")
if(NOT EXISTS "${QUICKFIX_INCLUDE_BASE}/quickfix")
    file(MAKE_DIRECTORY "${QUICKFIX_INCLUDE_BASE}")
    execute_process(
        COMMAND ${CMAKE_COMMAND} -E create_symlink "${QUICKFIX_SRC}" "${QUICKFIX_INCLUDE_BASE}/quickfix"
    )
endif()

# Replace dynamic exception specs for C++17 compatibility.
#   throw()            -> noexcept        (means "doesn't throw")
#   throw(SomeType)    -> noexcept(false)  (means "may throw")
# Runs once at configure time; stamp file prevents re-running.
# To re-run: delete build/quickfix_patched.stamp and reconfigure.
if(NOT EXISTS "${QUICKFIX_PATCH_STAMP}")
    message(STATUS "Patching quickfix throw() specs for C++17...")
    file(GLOB_RECURSE _qf_files
        "${QUICKFIX_SRC}/*.h"
        "${QUICKFIX_SRC}/*.cpp"
    )
    list(FILTER _qf_files EXCLUDE REGEX "pugixml\\.cpp$")
    foreach(_file IN LISTS _qf_files)
        file(READ "${_file}" _content)
        string(REGEX MATCH "throw[ ]*\\(" _has_throw "${_content}")
        if(_has_throw)
            # First: throw() with empty parens -> noexcept
            string(REGEX REPLACE "throw[ ]*\\([ ]*\\)" "noexcept" _content "${_content}")
            # Then: throw(Something) with content -> noexcept(false)
            string(REGEX REPLACE "throw[ ]*\\([^)]+\\)" "noexcept(false)" _content "${_content}")
            file(WRITE "${_file}" "${_content}")
        endif()
    endforeach()
    file(WRITE "${QUICKFIX_PATCH_STAMP}" "patched")
    message(STATUS "Patching quickfix throw() specs for C++17... done")
endif()

